# MiniMax API (server-only). Used directly by Nitro/server code.
NUXT_MINIMAX_API_KEY=api-key
NUXT_MINIMAX_BASE_URL=https://api.minimax.io/anthropic/v1
# GLM / Z.AI API (server-only). Used directly by Nitro/server code.
NUXT_GLM_API_KEY=api-key
NUXT_GLM_BASE_URL=https://api.z.ai/api/paas/v4

# Paperless-ngx API
# Docker Compose integrated Paperless stack:
NUXT_PAPERLESS_BASE_URL=http://webserver:8000
# Docker note: if Paperless runs on your host machine, use http://host.docker.internal:<port>
# NUXT_PAPERLESS_BASE_URL=http://host.docker.internal:8000
NUXT_PAPERLESS_API_TOKEN=your_paperless_token_here

# Paperless bootstrap admin user created by Docker Compose
PAPERLESS_BOOTSTRAP_USER=paperless
PAPERLESS_BOOTSTRAP_PASSWORD=paperless
PAPERLESS_BOOTSTRAP_EMAIL=paperless@example.local

# Ollama (external local LLM; not managed by Docker Compose)
# Local development outside Docker: http://localhost:11434
# App container to host Ollama: http://host.docker.internal:11434
NUXT_OLLAMA_BASE_URL=http://host.docker.internal:11434
NUXT_OLLAMA_MODEL=glm-ocr:latest

# Sync interval
NUXT_SYNC_INTERVAL_MS=5000

# Document Processing
NUXT_PROCESS_INTERVAL_MS=10000

# Docker Compose
APP_PORT=3000

# Integrated Paperless-ngx stack
PAPERLESS_PORT=8000
PAPERLESS_PUBLIC_URL=http://localhost:8000
PAPERLESS_SECRET_KEY=replace-with-a-long-random-secret
PAPERLESS_TIME_ZONE=America/Mexico_City
PAPERLESS_OCR_LANGUAGE=spa+eng
PAPERLESS_DB_POOLSIZE=10

# Integrated Paperless dependencies
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=replace-with-a-strong-password

# Pinned image versions. Keep explicit for reproducible deployments.
PAPERLESS_VERSION=2.20.15
POSTGRES_VERSION=18.3
REDIS_VERSION=8.6.2
GOTENBERG_VERSION=8.31.0
TIKA_VERSION=3.3.0.0
